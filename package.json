{
  "name": "@ashton/c",
  "version": "0.1.0",
  "description": "Claude Code session manager CLI",
  "type": "module",
  "bin": {
    "c": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsc && node dist/index.js",
    "test": "node --experimental-strip-types --experimental-test-module-mocks --test test/**/*.test.ts",
    "test:watch": "node --experimental-strip-types --experimental-test-module-mocks --test --watch test/**/*.test.ts",
    "test:coverage": "node --experimental-strip-types --experimental-test-module-mocks --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test test/**/*.test.ts",
    "test:lcov": "mkdir -p coverage && node --experimental-strip-types --experimental-test-module-mocks --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-reporter=spec --test-reporter=lcov --test-reporter-destination=stdout --test-reporter-destination=coverage/lcov.info --test test/**/*.test.ts",
    "test:html": "rm -rf coverage/v8 && NODE_V8_COVERAGE=coverage/v8 node --experimental-strip-types --experimental-test-module-mocks --test test/**/*.test.ts && node scripts/merge-v8-coverage.mjs coverage/v8 && npx c8 report --reporter=html --reports-dir=coverage/html --include='src/**/*.ts' --temp-directory=coverage/v8 && open coverage/html/index.html"
  },
  "dependencies": {
    "@iarna/toml": "^3.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.1",
    "human-readable-ids": "^1.0.4",
    "humanhash": "^1.0.4",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "omelette": "^0.4.17",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@bcoe/v8-coverage": "^1.0.2",
    "@types/iarna__toml": "^2.0.5",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.11.0",
    "@types/update-notifier": "^6.0.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
